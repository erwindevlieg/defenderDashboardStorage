.git*
.venv/
__pycache__/
*.py[cod]
.ruff_cache/
.pytest_cache/
.mypy_cache/

# Development tooling — runtime install only uses requirements.txt
requirements-dev.txt
pyproject.toml

# Tests
tests/

# Editor
.vscode/
